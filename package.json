{
  "name": "substragra",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "dev:legacy": "pnpm --filter @substragra/legacy dev",
    "build:legacy": "pnpm --filter @substragra/legacy build",
    "test": "playwright test --config=playwright.config.ts",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:ci": "playwright test --config=playwright.config.ts --reporter=list"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "turbo": "^1.13.4",
    "typescript": "^5.3.0"
  }
}
