{
  "name": "@stragra/onboarding-engine",
  "version": "1.0.0",
  "description": "Master Plan Onboarding Engine for Stragra - California AI Agency setup wizard",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./schemas/*": {
      "import": "./dist/schemas/*.js",
      "require": "./dist/schemas/*.js",
      "types": "./dist/schemas/*.d.ts"
    },
    "./constants/*": {
      "import": "./dist/constants/*.js",
      "require": "./dist/constants/*.js",
      "types": "./dist/constants/*.d.ts"
    },
    "./utils/*": {
      "import": "./dist/utils/*.js",
      "require": "./dist/utils/*.js",
      "types": "./dist/utils/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "keywords": [
    "onboarding",
    "master-plan",
    "llc",
    "real-estate",
    "ai-agency"
  ],
  "license": "MIT",
  "private": true
}
