generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users     User[]
  documents Document[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  tenantId  String   @map("tenant_id")
  role      String   @default("member")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Document {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  parentId          String?   @map("parent_id")
  name              String
  type              String // 'folder', 'file'
  mimeType          String?   @map("mime_type")
  sizeBytes         BigInt?   @map("size_bytes")
  storagePath       String?   @map("storage_path")
  isShared          Boolean   @default(false) @map("is_shared")
  sharedLinkToken   String?   @map("shared_link_token")
  sharedLinkExpiresAt DateTime? @map("shared_link_expires_at")
  createdBy         String?   @map("created_by")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Document?  @relation("FolderContents", fields: [parentId], references: [id], onDelete: Cascade)
  children Document[] @relation("FolderContents")

  @@unique([tenantId, parentId, name, deletedAt])
  @@index([tenantId])
  @@index([parentId])
  @@index([sharedLinkToken])
  @@map("documents")
}
